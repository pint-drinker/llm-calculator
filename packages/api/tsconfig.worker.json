{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "types": ["@cloudflare/workers-types"],
    "lib": ["ES2022", "WebWorker"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": false
  },
  "include": ["src/worker.ts", "src/hono-routes.ts", "src/middleware/**/*", "src/handlers.ts", "src/registry.ts", "src/mcp/server.ts"],
  "exclude": ["dist", "test", "node_modules", "src/index.ts", "src/server.ts", "src/mcp-stdio.ts", "src/mcp/transport.ts"]
}
